{
	"name": "infabo/typo3api",
	"type": "typo3-cms-extension",
	"license": "MIT",
	"keywords": [
		"TYPO3",
		"api",
		"TCA",
		"tsconfig",
		"ext_tables.php",
		"ext_localconf.php"
	],
	"support": {
		"issues": "https://github.com/infabo/typo3api/issues"
	},
	"authors": [
		{
			"name": "Marco Pfeiffer",
			"role": "Developer",
			"homepage": "https://www.marco.zone/"
		},
		{
			"name": "Ingo Fabbri",
			"role": "Developer"
		}
	],
	"extra": {
		"typo3/cms": {
			"web-dir": "web",
			"extension-key": "typo3api"
		}
	},
	"require": {
		"php": "^8.3",
		"symfony/intl": "^6 || ^7",
		"symfony/options-resolver": "^6 || ^7",
		"symfony/polyfill-mbstring": "^v1.33.0",
		"symfony/polyfill-php80": "^v1.33.0",
		"typo3/cms-backend": "^13.4 || ^14.3",
		"typo3/cms-core": "^13.4 || ^14.3",
		"typo3/cms-extbase": "^13.4 || ^14.3",
		"typo3/cms-frontend": "^13.4 || ^14.3",
		"typo3/cms-install": "^13.4 || ^14.3",
		"typo3/cms-lang": "^13.4 || ^14.3"
	},
	"autoload": {
		"psr-4": {
			"Typo3Api\\": "Classes"
		}
	},
	"require-dev": {
		"ssch/typo3-rector": "^v3.13.0",
		"symplify/easy-coding-standard": "^13.0.4",
		"typo3/testing-framework": "^9.4.0"
	},
	"autoload-dev": {
		"psr-4": {
			"Typo3Api\\": "Tests"
		}
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	}
}
